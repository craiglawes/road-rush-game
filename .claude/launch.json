{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Road Rush",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path');http.createServer((req,res)=>{let f=path.join('/Users/craiglawes/Documents/Projects/car-racing-game',req.url==='/'?'index.html':req.url);const ext=path.extname(f);const mime={'html':'text/html','css':'text/css','js':'application/javascript'}[ext.slice(1)]||'text/plain';fs.readFile(f,(e,d)=>{if(e){res.writeHead(404);res.end('Not found')}else{res.writeHead(200,{'Content-Type':mime});res.end(d)}})}).listen(process.env.PORT||4000,()=>console.log('ok'))"],
      "port": 4000,
      "autoPort": true
    }
  ]
}
